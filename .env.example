# Supabase (requerido para el build y la app)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase

# R2 / API (subida de archivos)
# Frontend (Vite): opcionales; por defecto API en mismo origen y multimedia.koronel.cl
VITE_API_URL=
VITE_R2_PUBLIC_URL=https://multimedia.koronel.cl

# Serverless API (Vercel Environment Variables): obligatorios para /api/upload/*
# R2_ACCOUNT_ID=tu-account-id
# R2_ACCESS_KEY_ID=tu-access-key
# R2_SECRET_ACCESS_KEY=tu-secret-key
# R2_BUCKET_NAME=koronel-media
# R2_PUBLIC_URL=https://multimedia.koronel.cl
# (Supabase ya configurado: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY)

# Opcionales (no necesarios para despliegue de prueba)
# VITE_OPENAI_API_KEY=
# VITE_GEMINI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_GA_MEASUREMENT_ID=
# VITE_ADSENSE_ID=
# VITE_PERPLEXITY_API_KEY=
# VITE_STRIPE_PUBLISHABLE_KEY=
